<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>家庭幸福原型测试</title>
  <style>
    :root {
      --ink: #20242b;
      --muted: #66727f;
      --line: rgba(32, 36, 43, .14);
      --paper: #fffdf8;
      --soft: #f5f8f4;
      --amber: #f5b44c;
      --coral: #ec786d;
      --sage: #72a978;
      --teal: #4d9aa8;
      --blue: #5e7fb8;
      --rose: #e78fa2;
      --shadow: 0 22px 70px rgba(31, 38, 54, .14);
      --radius: 8px;
    }

    * { box-sizing: border-box; }

    html {
      min-height: 100%;
      background:
        radial-gradient(circle at 8% 12%, rgba(245, 180, 76, .20), transparent 26%),
        radial-gradient(circle at 92% 18%, rgba(77, 154, 168, .16), transparent 28%),
        linear-gradient(135deg, #fff8ec 0%, #f5faf4 48%, #f4f7fb 100%);
      color: var(--ink);
      font-family: "Microsoft YaHei", "PingFang SC", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    body {
      min-height: 100%;
      margin: 0;
    }

    button {
      border: 0;
      color: inherit;
      font: inherit;
      cursor: pointer;
    }

    .shell {
      width: min(1160px, calc(100vw - 32px));
      margin: 0 auto;
      padding: 24px 0 34px;
    }

    .top {
      display: grid;
      grid-template-columns: minmax(0, 1.05fr) minmax(320px, .95fr);
      gap: 22px;
      align-items: stretch;
      min-height: calc(100vh - 58px);
    }

    .intro,
    .test,
    .result,
    .type-wall {
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: rgba(255, 253, 248, .86);
      box-shadow: var(--shadow);
      backdrop-filter: blur(18px);
    }

    .intro {
      padding: 26px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      gap: 26px;
    }

    .eyebrow {
      color: var(--teal);
      font-size: 13px;
      font-weight: 900;
      letter-spacing: 0;
    }

    h1,
    h2,
    h3,
    p {
      margin: 0;
    }

    h1 {
      max-width: 780px;
      margin-top: 8px;
      font-size: clamp(34px, 6vw, 70px);
      line-height: 1.02;
      letter-spacing: 0;
    }

    .lead {
      max-width: 680px;
      margin-top: 18px;
      color: #4a5563;
      font-size: 18px;
      line-height: 1.75;
    }

    .dimension-row {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 10px;
      margin-top: 28px;
    }

    .dimension {
      min-height: 118px;
      padding: 14px;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: rgba(255, 255, 255, .62);
      display: grid;
      align-content: start;
      gap: 8px;
    }

    .dimension strong {
      font-size: 18px;
    }

    .dimension span {
      color: var(--muted);
      font-size: 13px;
      line-height: 1.55;
    }

    .actions {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      align-items: center;
    }

    .primary,
    .secondary {
      min-height: 46px;
      padding: 0 18px;
      border-radius: var(--radius);
      font-weight: 900;
      transition: transform .16s ease, box-shadow .16s ease, background .16s ease;
    }

    .primary {
      background: var(--ink);
      color: white;
      box-shadow: 0 12px 26px rgba(32, 36, 43, .24);
    }

    .secondary {
      border: 1px solid var(--line);
      background: rgba(255, 255, 255, .72);
    }

    .primary:hover,
    .secondary:hover {
      transform: translateY(-1px);
    }

    .stage {
      display: grid;
      grid-template-rows: auto minmax(0, 1fr);
      gap: 14px;
    }

    .family-scene {
      position: relative;
      min-height: 360px;
      overflow: hidden;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background:
        linear-gradient(180deg, rgba(255,255,255,.18), rgba(255,255,255,.68)),
        var(--scene-bg, linear-gradient(135deg, #ffe2b5, #b8d8cf));
      box-shadow: var(--shadow);
    }

    .scene-sky,
    .scene-floor,
    .symbol,
    .family,
    .prop {
      position: absolute;
      inset: 0;
    }

    .scene-sky {
      opacity: .9;
      background:
        radial-gradient(circle at 26% 20%, rgba(255,255,255,.8) 0 5%, transparent 6%),
        radial-gradient(circle at 62% 18%, rgba(255,255,255,.52) 0 3%, transparent 4%);
    }

    .scene-floor {
      top: auto;
      height: 36%;
      background: rgba(255,255,255,.36);
      border-top: 1px solid rgba(32,36,43,.08);
    }

    .symbol {
      display: grid;
      place-items: center;
      padding-bottom: 42px;
      font-size: clamp(116px, 19vw, 210px);
      line-height: 1;
      opacity: .92;
      filter: drop-shadow(0 12px 22px rgba(32, 36, 43, .10));
    }

    .symbol svg {
      width: min(58%, 280px);
      height: auto;
      overflow: visible;
    }

    .family {
      display: flex;
      justify-content: center;
      align-items: flex-end;
      gap: 9px;
      padding-bottom: 32px;
      pointer-events: none;
    }

    .person {
      position: relative;
      width: 58px;
      height: 142px;
      transform: translateY(var(--raise, 0));
    }

    .person.child {
      width: 46px;
      height: 104px;
      --raise: 18px;
    }

    .head {
      position: absolute;
      left: 50%;
      top: 0;
      width: 45px;
      height: 45px;
      transform: translateX(-50%);
      border: 2px solid rgba(32,36,43,.7);
      border-radius: 50% 50% 46% 46%;
      background: #ffd7b6;
      overflow: hidden;
      box-shadow: inset 0 -4px 0 rgba(213, 122, 92, .16);
      z-index: 4;
    }

    .child .head {
      width: 42px;
      height: 42px;
    }

    .hair {
      position: absolute;
      left: -3px;
      top: -5px;
      width: 52px;
      height: 24px;
      border-radius: 22px 22px 10px 10px;
      background: var(--hair);
      z-index: 1;
    }

    .child .hair {
      left: -2px;
      top: -4px;
      width: 46px;
      height: 19px;
      border-radius: 19px 19px 10px 10px;
    }

    .eye {
      position: absolute;
      top: 24px;
      width: 5px;
      height: 6px;
      border-radius: 50%;
      background: #28313c;
      z-index: 3;
    }

    .eye.left { left: 14px; }
    .eye.right { right: 14px; }
    .child .eye { top: 22px; }
    .child .eye.left { left: 13px; }
    .child .eye.right { right: 13px; }

    .smile {
      position: absolute;
      left: 50%;
      bottom: 9px;
      width: 14px;
      height: 7px;
      transform: translateX(-50%);
      border-bottom: 2px solid rgba(32,36,43,.72);
      border-radius: 0 0 99px 99px;
      z-index: 3;
    }

    .body {
      position: absolute;
      left: 50%;
      top: 43px;
      width: 54px;
      height: 78px;
      transform: translateX(-50%);
      border: 2px solid rgba(32,36,43,.64);
      border-radius: 18px 18px 12px 12px;
      background: var(--clothes);
      z-index: 2;
    }

    .child .body {
      top: 40px;
      width: 42px;
      height: 50px;
      border-radius: 16px 16px 11px 11px;
    }

    .leg {
      position: absolute;
      bottom: 0;
      width: 19px;
      height: 28px;
      border-radius: 0 0 8px 8px;
      background: #334454;
    }

    .leg.left { left: 10px; }
    .leg.right { right: 10px; }
    .child .leg {
      width: 15px;
      height: 18px;
      background: #5c82b7;
    }

    .scene-caption {
      position: absolute;
      left: 16px;
      right: 16px;
      bottom: 14px;
      display: flex;
      justify-content: space-between;
      align-items: end;
      gap: 12px;
      color: rgba(32,36,43,.86);
    }

    .scene-caption strong {
      font-size: 28px;
      line-height: 1;
    }

    .scene-caption span {
      color: rgba(32,36,43,.64);
      font-size: 13px;
      font-weight: 800;
      text-align: right;
    }

    .test,
    .result {
      padding: 18px;
      display: none;
      min-height: 424px;
    }

    .test.active,
    .result.active {
      display: grid;
      gap: 16px;
      align-content: start;
    }

    .progress-meta {
      display: flex;
      justify-content: space-between;
      gap: 14px;
      color: var(--muted);
      font-size: 13px;
      font-weight: 800;
    }

    .progress {
      height: 9px;
      overflow: hidden;
      border-radius: 99px;
      background: rgba(32,36,43,.08);
    }

    .bar {
      width: 0%;
      height: 100%;
      border-radius: inherit;
      background: linear-gradient(90deg, var(--coral), var(--amber), var(--teal));
      transition: width .22s ease;
    }

    .question {
      min-height: 94px;
      font-size: clamp(22px, 3vw, 32px);
      font-weight: 950;
      line-height: 1.28;
      letter-spacing: 0;
    }

    .options {
      display: grid;
      gap: 10px;
    }

    .option {
      min-height: 84px;
      padding: 16px;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: rgba(255,255,255,.72);
      text-align: left;
      display: grid;
      grid-template-columns: 34px minmax(0, 1fr);
      align-items: center;
      gap: 12px;
      transition: transform .16s ease, background .16s ease, border-color .16s ease;
    }

    .option:hover,
    .option.selected {
      transform: translateY(-1px);
      border-color: rgba(32,36,43,.34);
      background: #fff;
    }

    .option b {
      width: 34px;
      height: 34px;
      display: grid;
      place-items: center;
      border-radius: 50%;
      background: var(--ink);
      color: #fff;
      font-size: 15px;
    }

    .nav {
      display: flex;
      justify-content: space-between;
      gap: 10px;
    }

    .result h2 {
      font-size: clamp(28px, 4vw, 48px);
      line-height: 1.06;
    }

    .result-copy {
      color: #4a5563;
      font-size: 16px;
      line-height: 1.7;
    }

    .chips {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .chip {
      padding: 8px 10px;
      border: 1px solid var(--line);
      border-radius: 99px;
      background: rgba(255,255,255,.68);
      color: #3d4651;
      font-size: 13px;
      font-weight: 900;
    }

    .bars {
      display: grid;
      gap: 11px;
    }

    .score-line {
      display: grid;
      gap: 6px;
    }

    .score-label {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      color: #3e4854;
      font-size: 13px;
      font-weight: 900;
    }

    .track {
      height: 10px;
      border-radius: 99px;
      background: rgba(32,36,43,.08);
      overflow: hidden;
    }

    .fill {
      height: 100%;
      width: 50%;
      border-radius: inherit;
      background: var(--track-color);
    }

    .type-wall {
      margin-top: 18px;
      padding: 18px;
    }

    .type-wall h2 {
      font-size: 26px;
      margin-bottom: 12px;
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 10px;
    }

    .mini-card {
      min-height: 138px;
      padding: 10px;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      background: var(--mini-bg);
      display: grid;
      align-content: space-between;
      overflow: hidden;
      position: relative;
    }

    .mini-card::before {
      content: "";
      position: absolute;
      right: -18px;
      top: -18px;
      width: 82px;
      height: 82px;
      border-radius: 50%;
      background: rgba(255,255,255,.42);
    }

    .mini-symbol {
      position: relative;
      font-size: 38px;
      font-weight: 950;
    }

    .mini-card strong,
    .mini-card span {
      position: relative;
    }

    .mini-card strong {
      font-size: 16px;
    }

    .mini-card span {
      color: rgba(32,36,43,.65);
      font-size: 12px;
      line-height: 1.45;
    }

    @media (max-width: 900px) {
      .top {
        grid-template-columns: 1fr;
        min-height: auto;
      }

      .dimension-row,
      .grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .family-scene {
        min-height: 310px;
      }
    }

    @media (max-width: 560px) {
      .shell {
        width: min(100% - 20px, 1160px);
        padding-top: 10px;
      }

      .intro,
      .test,
      .result,
      .type-wall {
        padding: 14px;
      }

      .dimension-row,
      .grid {
        grid-template-columns: 1fr;
      }

      .family-scene {
        min-height: 260px;
      }

      .symbol svg {
        width: 72%;
      }

      .person {
        transform: scale(.82) translateY(14px);
        transform-origin: bottom center;
      }

      .scene-caption strong {
        font-size: 22px;
      }
    }
  </style>
</head>
<body>
  <main class="shell">
    <section class="top">
      <div class="intro">
        <div>
          <div class="eyebrow">20 题家庭幸福原型测试</div>
          <h1>看看你家的幸福，像哪一种风景</h1>
          <p class="lead">这不是诊断，而是一套家庭关系风格分类。它参考“经济安全、身心健康、亲密关系、亲子互动、代际边界、沟通修复、性别分工、决策公平、工作家庭平衡、情绪安全、社会支持、共同目标”等影响因素，把家庭幸福拆成 16 种原型。</p>
          <div class="dimension-row">
            <div class="dimension">
              <strong>O / R</strong>
              <span>开放表达，还是克制表达。</span>
            </div>
            <div class="dimension">
              <strong>E / P</strong>
              <span>情绪支持，还是实用支持。</span>
            </div>
            <div class="dimension">
              <strong>C / I</strong>
              <span>亲密陪伴，还是独立空间。</span>
            </div>
            <div class="dimension">
              <strong>M / A</strong>
              <span>主动修复，还是自然缓和。</span>
            </div>
          </div>
        </div>
        <div class="actions">
          <button class="primary" id="startBtn">开始测试</button>
          <button class="secondary" id="demoBtn">随机看一个结果</button>
        </div>
      </div>

      <div class="stage">
        <div class="family-scene" id="scene">
          <div class="scene-sky"></div>
          <div class="scene-floor"></div>
          <div class="symbol" id="sceneSymbol"></div>
          <div class="family">
            <div class="person father" style="--hair:#25364b;--clothes:#eef1df">
              <div class="head"><div class="hair"></div><div class="eye left"></div><div class="eye right"></div><div class="smile"></div></div>
              <div class="body"></div><div class="leg left"></div><div class="leg right"></div>
            </div>
            <div class="person child" style="--hair:#20242b;--clothes:#f5c84b">
              <div class="head"><div class="hair"></div><div class="eye left"></div><div class="eye right"></div><div class="smile"></div></div>
              <div class="body"></div><div class="leg left"></div><div class="leg right"></div>
            </div>
            <div class="person mother" style="--hair:#8b503c;--clothes:#e98d84">
              <div class="head"><div class="hair"></div><div class="eye left"></div><div class="eye right"></div><div class="smile"></div></div>
              <div class="body"></div><div class="leg left"></div><div class="leg right"></div>
            </div>
          </div>
          <div class="scene-caption">
            <strong id="sceneTitle">暖炉型家庭</strong>
            <span id="sceneLine">情绪被接住，关系被照亮</span>
          </div>
        </div>

        <section class="test active" id="testPanel">
          <div>
            <div class="progress-meta">
              <span id="stepLabel">第 1 / 20 题</span>
              <span id="dimensionLabel">表达方式 O/R</span>
            </div>
            <div class="progress"><div class="bar" id="bar"></div></div>
          </div>
          <div class="question" id="questionText"></div>
          <div class="options">
            <button class="option" id="optionA"><b>A</b><span></span></button>
            <button class="option" id="optionB"><b>B</b><span></span></button>
          </div>
          <div class="nav">
            <button class="secondary" id="prevBtn">上一题</button>
            <button class="secondary" id="resetBtn">重新开始</button>
          </div>
        </section>

        <section class="result" id="resultPanel">
          <div class="eyebrow" id="resultCode"></div>
          <h2 id="resultName"></h2>
          <p class="result-copy" id="resultDesc"></p>
          <div class="chips" id="chips"></div>
          <div class="bars" id="bars"></div>
          <div class="actions">
            <button class="primary" id="againBtn">再测一次</button>
            <button class="secondary" id="randomBtn">换个类型预览</button>
          </div>
        </section>
      </div>
    </section>

    <section class="type-wall">
      <h2>16 种家庭场景原型</h2>
      <div class="grid" id="typeGrid"></div>
    </section>
  </main>

  <script>
    const questions = [
      { axis: "OR", label: "表达方式 O/R", q: "家里有人感到压力、委屈或疲惫时，我们通常会？", a: "允许对方说出真实感受，并认真听完。", b: "先让对方自己缓一缓，不急着追问。" },
      { axis: "OR", label: "表达方式 O/R", q: "讨论家务、育儿、老人照料这类分工问题时，我们更像？", a: "把各自承担了什么、累在哪里讲清楚。", b: "尽量靠自觉和默契，不把账算得太细。" },
      { axis: "OR", label: "表达方式 O/R", q: "遇到孩子教育、居住安排或重大消费时，我们通常会？", a: "让相关家庭成员表达意见，再一起决定。", b: "由更有经验或更能负责的人来拿主意。" },
      { axis: "OR", label: "表达方式 O/R", q: "家里出现不满时，我们更常见的是？", a: "把具体问题说出来，避免憋成情绪。", b: "先忍一忍，维持家里的平静。" },
      { axis: "OR", label: "表达方式 O/R", q: "当家庭成员心理状态不好时，我们更倾向于？", a: "承认这件事需要被看见和讨论。", b: "少说一点，先把日子稳定过下去。" },

      { axis: "EP", label: "支持方式 E/P", q: "家人遇到困难时，我们第一反应更像？", a: "先安慰、理解，让对方觉得不是一个人。", b: "先分析资源、钱、时间和解决办法。" },
      { axis: "EP", label: "支持方式 E/P", q: "面对经济、健康或工作压力，家里最需要的是？", a: "有人能接住焦虑，让气氛不继续恶化。", b: "有人能做计划、分任务、找外部资源。" },
      { axis: "EP", label: "支持方式 E/P", q: "孩子或老人需要照料时，我们更看重？", a: "照料过程里的耐心、尊重和情绪回应。", b: "照料安排是否清楚、稳定、可执行。" },
      { axis: "EP", label: "支持方式 E/P", q: "让我觉得家庭可靠的主要原因是？", a: "我脆弱时可以被理解，不会被嘲笑。", b: "出事时家里能迅速分担，帮我顶上。" },
      { axis: "EP", label: "支持方式 E/P", q: "家人表达关心时，最打动我的是？", a: "愿意听我说，并回应我的感受。", b: "实际帮我减轻负担，解决麻烦。" },

      { axis: "CI", label: "相处节奏 C/I", q: "家庭仪式感对我们来说更像？", a: "固定一起吃饭、散步、过节，能增强归属感。", b: "不必固定形式，只要彼此心里有家就好。" },
      { axis: "CI", label: "相处节奏 C/I", q: "亲子或代际关系里，我们更重视？", a: "多陪伴、多参与，让关系保持热度。", b: "有边界、有空间，避免互相干预太多。" },
      { axis: "CI", label: "相处节奏 C/I", q: "工作很忙或通勤很累时，我们更希望家庭怎么安排？", a: "尽量留出共同时间，别让关系只剩事务。", b: "尊重各自休息节奏，不强求陪伴频率。" },
      { axis: "CI", label: "相处节奏 C/I", q: "亲友、祖辈或外部支持介入家庭时，我们更倾向于？", a: "把支持纳入家庭共同生活，形成互助网络。", b: "感谢支持，但保留小家庭自己的节奏。" },
      { axis: "CI", label: "相处节奏 C/I", q: "我理想中的幸福家庭更像？", a: "大家经常聚在一起，有共同目标和仪式。", b: "大家各自发展，但在关键时刻彼此可靠。" },

