    const scores = { O: 0, R: 0, E: 0, P: 0, C: 0, I: 0, M: 0, A: 0 };
    const answers = Array(questions.length).fill(null);
    let index = 0;

    const scene = document.querySelector("#scene");
    const sceneSymbol = document.querySelector("#sceneSymbol");
    const sceneTitle = document.querySelector("#sceneTitle");
    const sceneLine = document.querySelector("#sceneLine");
    const testPanel = document.querySelector("#testPanel");
    const resultPanel = document.querySelector("#resultPanel");
    const questionText = document.querySelector("#questionText");
    const stepLabel = document.querySelector("#stepLabel");
    const dimensionLabel = document.querySelector("#dimensionLabel");
    const bar = document.querySelector("#bar");
    const optionA = document.querySelector("#optionA");
    const optionB = document.querySelector("#optionB");
    const resultCode = document.querySelector("#resultCode");
    const resultName = document.querySelector("#resultName");
    const resultDesc = document.querySelector("#resultDesc");
    const chips = document.querySelector("#chips");
    const bars = document.querySelector("#bars");
    const typeGrid = document.querySelector("#typeGrid");

    function axisLetters(axis) {
      return axis.split("");
    }

    function applyAnswer(question, answer, direction) {
      if (!answer) return;
      const [left, right] = axisLetters(question.axis);
      scores[answer === "A" ? left : right] += direction;
    }

    function chooseType() {
      return [
        scores.O >= scores.R ? "O" : "R",
        scores.E >= scores.P ? "E" : "P",
        scores.C >= scores.I ? "C" : "I",
        scores.M >= scores.A ? "M" : "A"
      ].join("");
    }

    function setScene(code) {
      const type = types[code] || types.OECM;
      scene.style.setProperty("--scene-bg", type.bg);
      sceneSymbol.innerHTML = symbols[type.symbol];
      sceneTitle.textContent = type.name;
      sceneLine.textContent = type.line;
    }

    function renderQuestion() {
      const q = questions[index];
      const selected = answers[index];
      stepLabel.textContent = `第 ${index + 1} / ${questions.length} 题`;
      dimensionLabel.textContent = q.label;
      bar.style.width = `${(index / questions.length) * 100}%`;
      questionText.textContent = q.q;
      optionA.querySelector("span").textContent = q.a;
      optionB.querySelector("span").textContent = q.b;
      optionA.classList.toggle("selected", selected === "A");
      optionB.classList.toggle("selected", selected === "B");
      document.querySelector("#prevBtn").disabled = index === 0;
      setScene(chooseType());
    }

    function answer(value) {
      const q = questions[index];
      applyAnswer(q, answers[index], -1);
      answers[index] = value;
      applyAnswer(q, value, 1);
      if (index < questions.length - 1) {
        index += 1;
        renderQuestion();
      } else {
        showResult();
      }
    }

    function showResult(code = chooseType()) {
      const type = types[code];
      bar.style.width = "100%";
      setScene(code);
      testPanel.classList.remove("active");
      resultPanel.classList.add("active");
      resultCode.textContent = `${code} · ${type.motif}`;
      resultName.textContent = type.name;
      resultDesc.textContent = type.desc;
      chips.innerHTML = type.tags.map(tag => `<span class="chip">${tag}</span>`).join("");
      bars.innerHTML = [
        ["表达", "O 开放", scores.O, "R 克制", scores.R, "var(--coral)"],
        ["支持", "E 情绪", scores.E, "P 实用", scores.P, "var(--amber)"],
        ["相处", "C 亲密", scores.C, "I 独立", scores.I, "var(--sage)"],
        ["冲突", "M 修复", scores.M, "A 缓和", scores.A, "var(--teal)"]
      ].map(row => {
        const total = row[2] + row[4] || 5;
        const pct = Math.round((row[2] / total) * 100);
        return `<div class="score-line">
          <div class="score-label"><span>${row[0]}：${row[1]} ${row[2]}</span><span>${row[3]} ${row[4]}</span></div>
          <div class="track"><div class="fill" style="width:${pct}%;--track-color:${row[5]}"></div></div>
        </div>`;
      }).join("");
    }

    function reset() {
      Object.keys(scores).forEach(key => scores[key] = 0);
      answers.fill(null);
      index = 0;
      resultPanel.classList.remove("active");
      testPanel.classList.add("active");
      renderQuestion();
    }

    function randomResult() {
      const keys = Object.keys(types);
      const code = keys[Math.floor(Math.random() * keys.length)];
      showResult(code);
    }

    function renderGrid() {
      typeGrid.innerHTML = Object.entries(types).map(([code, type]) => `
        <button class="mini-card" style="--mini-bg:${type.bg}" data-code="${code}">
          <div class="mini-symbol">${code}</div>
          <strong>${type.name}</strong>
          <span>${type.motif}<br>${type.line}</span>
        </button>
      `).join("");
      typeGrid.querySelectorAll(".mini-card").forEach(card => {
        card.addEventListener("click", () => showResult(card.dataset.code));
      });
    }

    optionA.addEventListener("click", () => answer("A"));
    optionB.addEventListener("click", () => answer("B"));
    document.querySelector("#prevBtn").addEventListener("click", () => {
      if (index > 0) {
        index -= 1;
        renderQuestion();
      }
    });
    document.querySelector("#resetBtn").addEventListener("click", reset);
    document.querySelector("#againBtn").addEventListener("click", reset);
    document.querySelector("#startBtn").addEventListener("click", reset);
    document.querySelector("#demoBtn").addEventListener("click", randomResult);
    document.querySelector("#randomBtn").addEventListener("click", randomResult);

    renderGrid();
    reset();
  </script>
</body>
</html>
